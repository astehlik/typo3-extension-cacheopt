includes:
  - ../../.Build/vendor/bnf/phpstan-psr-container/extension.neon
  - ../../.Build/vendor/phpstan/phpstan-phpunit/extension.neon

parameters:
  # Use local .cache dir instead of /tmp
  tmpDir: ../../.cache/phpstan

  level: 5

  paths:
    - ../../Classes
    - ../../Tests

  stubFiles:
    - ../../Tests/PHPStan/Tests.php
